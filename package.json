{
    "name": "swg-theme",
    "version": "1.0.4",
    "private": true,
    "description": "Official Astro Theme Starter for Static Website Generator.",
    "type": "module",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "check": "astro check",
        "validate": "node bin/swg.mjs validate",
        "package": "node bin/swg.mjs package",
        "sync-version": "node bin/swg.mjs sync-version",
        "release": "semantic-release",
        "release:dry": "semantic-release --dry-run"
    },
    "dependencies": {
        "astro": "^7.0.7",
        "marked": "^18.0.6"
    },
    "devDependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.9",
        "@semantic-release/release-notes-generator": "^14.1.1",
        "@types/node": "^26.1.1",
        "semantic-release": "^25.0.7"
    }
}
