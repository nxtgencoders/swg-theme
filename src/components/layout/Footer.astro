---
import {
    getMenu
}
from '../../lib/menus';

import {
    getSettings
}
from '../../lib/settings';

const menu =
    getMenu(
        'footer'
    );

const settings =
    getSettings();
---

<footer
    class="border-t border-slate-200 bg-slate-950 text-slate-300"
>

    <div
        class="mx-auto grid max-w-7xl gap-12 px-6 py-20 md:grid-cols-4 lg:px-8"
    >

        {
            menu?.categories.map(
                category => (

                    <div>

                        <h3
                            class="font-semibold text-white"
                        >

                            {category.title}

                        </h3>

                        <ul
                            class="mt-6 space-y-3"
                        >

                            {
                                category.items.map(
                                    item => (

                                        <li>

                                            <a
                                                href={item.url}
                                                target={item.target || undefined}
                                                class="transition hover:text-white"
                                            >

                                                {item.label}

                                            </a>

                                        </li>

                                    )
                                )
                            }

                        </ul>

                    </div>

                )
            )
        }

    </div>

    <div
        class="border-t border-slate-800"
    >

        <div
            class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 text-sm text-slate-500 md:flex-row lg:px-8"
        >

            <p>

                {settings.footer}

            </p>

            <div
                class="flex items-center gap-6"
            >

                <a
                    href="https://astro.build"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transition hover:text-white"
                >

                    Astro

                </a>

                <a
                    href="https://tailwindcss.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transition hover:text-white"
                >

                    Tailwind CSS

                </a>

                <a
                    href="https://github.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transition hover:text-white"
                >

                    GitHub

                </a>

            </div>

        </div>

    </div>

</footer>