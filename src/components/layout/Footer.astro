---
import {
    getMenu
}
from '../../lib/menus';

import {
    getSettings
}
from '../../lib/settings';

const menu =
    getMenu(
        'footer'
    );

const settings =
    getSettings();
---

<footer
    class="border-t border-slate-200 bg-slate-950 text-slate-300"
>

    <div
        class="mx-auto grid max-w-7xl gap-12 px-6 py-20 md:grid-cols-4 lg:px-8"
    >

<div>

    <a
        href={settings.site_url}
        class="text-2xl font-extrabold tracking-tight text-white"
    >

        {settings.site_name}

    </a>

    <p
        class="mt-6 leading-7 text-slate-400"
    >

        {settings.tagline}

    </p>

</div>


{
    menu?.categories

        .filter(
            category =>
                category.title !== 'Technology'
        )

        .map(
            category => (

                <div>

                    <h3
                        class="font-semibold text-white"
                    >

                        {category.title}

                    </h3>

                    <ul
                        class="mt-6 space-y-3"
                    >

                        {
                            category.items.map(
                                item => (

                                    <li>

                                        <a
                                            href={item.url}
                                            target={item.target || undefined}
                                            rel={
                                                item.target === '_blank'
                                                    ? 'noopener noreferrer'
                                                    : undefined
                                            }
                                            class="transition hover:text-white"
                                        >

                                            {item.label}

                                        </a>

                                    </li>

                                )
                            )
                        }

                    </ul>

                </div>

            )
        )
}

    </div>

    <div
        class="border-t border-slate-800"
    >

        <div
            class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 text-sm text-slate-500 md:flex-row lg:px-8"
        >

            <p>

                {settings.footer}

            </p>

                <div
                    class="flex items-center gap-6"
                >

            {
                menu?.categories
                    .find(
                        category =>
                            category.title === 'Technology'
                    )
                    ?.items.map(
                        item => (

                            <a
                                href={item.url}
                                target={item.target || undefined}
                                rel={
                                    item.target === '_blank'
                                        ? 'noopener noreferrer'
                                        : undefined
                                }
                                class="transition hover:text-white"
                            >

                                {item.label}

                            </a>

                        )
                    )
            }

                </div>

        </div>

    </div>

</footer>