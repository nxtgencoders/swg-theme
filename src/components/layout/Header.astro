---
import {
    getMenu
}
from '../../lib/menus';

const menu =
    getMenu(
        'main'
    );

const logo =
    menu?.categories.find(
        category =>
            category.title === 'Logo'
    );

const navigation =
    menu?.categories.find(
        category =>
            category.title === 'Navigation'
    );

const cta =
    menu?.categories.find(
        category =>
            category.title === 'CTA'
    );
---

<header
    class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur"
>

    <div
        class="mx-auto flex h-18 max-w-7xl items-center justify-between px-6 lg:px-8"
    >

        {
            logo?.items[0] && (

                <a
                    href={logo.items[0].url}
                    class="flex items-center gap-3"
                >

                    <div
                        class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#299B36]/10 text-[#299B36]"
                    >

                        <i
                            data-lucide="blocks"
                            class="h-6 w-6"
                        ></i>

                    </div>

                    <span
                        class="text-[34px] font-extrabold tracking-tight text-[#1C64A5]"
                    >

                        {logo.items[0].label}

                    </span>

                </a>

            )
        }

        <nav
            class="hidden items-center gap-8 text-sm font-medium text-slate-700 md:flex"
        >

            {
                navigation?.items.map(
                    item => (

                        <a
                            href={item.url}
                            class="transition hover:text-[#1C64A5]"
                            target={item.target || undefined}
                        >

                            {item.label}

                        </a>

                    )
                )
            }

        </nav>

        {
            cta?.items[0] && (

                <a
                    href={cta.items[0].url}
                    class="rounded-lg bg-[#1C64A5] px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#17548a] hover:opacity-90"
                    target={cta.items[0].target || undefined}
                >

                    {cta.items[0].label}

                </a>

            )
        }

    </div>

</header>