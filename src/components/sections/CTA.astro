---
const {
    data
} = Astro.props;
---

<section
    class="py-24"
>

    <div
        class="mx-auto max-w-5xl px-6 lg:px-8"
    >

        <div
            class="overflow-hidden rounded-3xl bg-[#1C64A5] px-8 py-20 text-center shadow-2xl lg:px-20"
        >

            {
                data.eyebrow && (

                    <span
                        class="text-sm font-semibold uppercase tracking-widest text-blue-100"
                    >

                        {data.eyebrow}

                    </span>

                )
            }

            {
                data.title && (

                    <h2
                        class="mt-6 text-4xl font-extrabold tracking-tight text-white lg:text-5xl"
                    >

                        {data.title}

                    </h2>

                )
            }

            {
                data.subtitle && (

                    <p
                        class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-blue-100"
                    >

                        {data.subtitle}

                    </p>

                )
            }

            {
                data.buttons?.length > 0 && (

                    <div
                        class="mt-10 flex flex-wrap justify-center gap-4"
                    >

                        {
                            data.buttons.map(
                                button => (

                                    <a
                                        href={button.url}
                                        class={
                                            button.variant === 'secondary'

                                                ? 'rounded-xl border border-white/30 px-6 py-3 font-semibold text-white transition hover:bg-white/10'

                                                : 'rounded-xl bg-white px-6 py-3 font-semibold text-[#1C64A5] transition hover:bg-slate-100'
                                        }
                                    >

                                        {button.label}

                                    </a>

                                )
                            )
                        }

                    </div>

                )
            }

            {
                data.note && (

                    <p
                        class="mt-8 text-sm text-blue-200"
                    >

                        {data.note}

                    </p>

                )
            }

        </div>

    </div>

</section>