---
const {
    data
} = Astro.props;
---

<section
    class="bg-slate-50 py-24"
>

    <div
        class="mx-auto max-w-4xl px-6 lg:px-8"
    >

        <div
            class="text-center"
        >

            {
                data.eyebrow && (

                    <span
                        class="text-sm font-semibold uppercase tracking-widest text-[#1C64A5]"
                    >

                        {data.eyebrow}

                    </span>

                )
            }

            {
                data.title && (

                    <h2
                        class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900"
                    >

                        {data.title}

                    </h2>

                )
            }

            {
                data.subtitle && (

                    <p
                        class="mt-6 text-lg leading-8 text-slate-600"
                    >

                        {data.subtitle}

                    </p>

                )
            }

        </div>

        {
            data.items?.length > 0 && (

                <div
                    class="mt-16 space-y-4"
                >

                    {
                        data.items.map(
                            item => (

                                <details
                                    class="rounded-2xl border border-slate-200 bg-white p-6"
                                >

                                    <summary
                                        class="cursor-pointer text-lg font-semibold text-slate-900"
                                    >

                                        {item.question}

                                    </summary>

                                    <p
                                        class="mt-4 leading-7 text-slate-600"
                                    >

                                        {item.answer}

                                    </p>

                                </details>

                            )
                        )
                    }

                </div>

            )
        }

    </div>

</section>