---
const {
    data
} = Astro.props;
---

<section
    class="py-24"
>

    <div
        class="mx-auto max-w-7xl px-6 lg:px-8"
    >

        <div
            class="mx-auto max-w-3xl text-center"
        >

            {
                data.eyebrow && (

                    <span
                        class="text-sm font-semibold uppercase tracking-widest text-[#1C64A5]"
                    >

                        {data.eyebrow}

                    </span>

                )
            }

            {
                data.title && (

                    <h2
                        class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900"
                    >

                        {data.title}

                    </h2>

                )
            }

            {
                data.subtitle && (

                    <p
                        class="mt-6 text-lg leading-8 text-slate-600"
                    >

                        {data.subtitle}

                    </p>

                )
            }

        </div>

        {
            data.cards?.length > 0 && (

                <div
                    class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3"
                >

                    {
                        data.cards.map(
                            card => (

                                <article
                                    class="rounded-2xl border border-slate-200 bg-white p-8 transition hover:-translate-y-1 hover:shadow-xl"
                                >

                                    {
                                        card.icon && (

                                            <div
                                                class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-100 text-[#1C64A5]"
                                            >

                                                <i
                                                    data-lucide={card.icon}
                                                    class="h-6 w-6"
                                                ></i>

                                            </div>

                                        )
                                    }

                                    {
                                        card.title && (

                                            <h3
                                                class="mt-6 text-xl font-bold"
                                            >

                                                {card.title}

                                            </h3>

                                        )
                                    }

                                    {
                                        card.description && (

                                            <p
                                                class="mt-4 leading-7 text-slate-600"
                                            >

                                                {card.description}

                                            </p>

                                        )
                                    }

                                </article>

                            )
                        )
                    }

                </div>

            )
        }

    </div>

</section>