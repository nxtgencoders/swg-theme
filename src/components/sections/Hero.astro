---
import CodeBlock
    from '../components/marketing/CodeBlock.astro';

const code = `{
  "title": "Homepage",
  "template": "homepage"
}`;
---




<section
    class="overflow-hidden py-24 sm:py-32"
>

    <div
        class="mx-auto grid max-w-7xl items-center gap-16 px-6 lg:grid-cols-2 lg:px-8"
    >

        <div>

            <span
                class="inline-flex rounded-full border border-blue-200 bg-blue-50 px-4 py-1 text-sm font-medium text-[#1C64A5]"
            >

                Static Website Generator

            </span>

            <h1
                class="mt-6 text-5xl font-extrabold leading-tight tracking-tight text-slate-900 lg:text-6xl"
            >

                Build blazing fast
                <span class="text-[#1C64A5]">
                    static websites
                </span>
                with Astro.

            </h1>

            <p
                class="mt-6 max-w-xl text-lg leading-8 text-slate-600"
            >

                Create blogs, documentation websites and business
                websites using JSON content, Astro themes and a modern
                publishing workflow.

            </p>

            <div
                class="mt-10 flex flex-wrap gap-4"
            >

                <a
                    href="/docs/getting-started"
                    class="rounded-lg bg-[#1C64A5] px-6 py-3 font-semibold text-white transition hover:opacity-90"
                >

                    Get Started

                </a>

                <a
                    href="/themes"
                    class="rounded-lg border border-slate-300 px-6 py-3 font-semibold text-slate-700 transition hover:border-[#1C64A5] hover:text-[#1C64A5]"
                >

                    Browse Themes

                </a>

            </div>

            <p
                class="mt-6 text-sm text-slate-500"
            >

                Free • Open Source • Built with Astro

            </p>

        </div>

        <div>

            <CodeBlock
                code={code}
            />
        </div>

    </div>

</section>