---
import CodeBlock
    from '../marketing/CodeBlock.astro';

const {
    data
} = Astro.props;
---

<section
    class="overflow-hidden py-16 sm:py-20 lg:py-24"
>

    <div
        class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-[1fr_1.1fr] lg:gap-20 lg:px-8"
    >

        <div
            class="max-w-2xl"
        >

            {
                data.eyebrow && (

                    <span
                        class="inline-flex rounded-full border border-blue-200 bg-blue-50 px-4 py-1 text-sm font-medium text-[#1C64A5]"
                    >

                        {data.eyebrow}

                    </span>

                )
            }

            <h1
                class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
            >

                {data.title}

                {
                    data.highlight && (

                        <span
                            class="mt-2 block text-[#1C64A5]"
                        >

                            {data.highlight}

                        </span>

                    )
                }

            </h1>

            {
                data.subtitle && (

                    <p
                        class="mt-8 max-w-xl text-lg leading-8 text-slate-600"
                    >

                        {data.subtitle}

                    </p>

                )
            }

            {
                data.buttons?.length > 0 && (

                    <div
                        class="mt-10 flex flex-col gap-4 sm:flex-row"
                    >

                        {
                            data.buttons.map(
                                button => (

                                    <a
                                        href={button.url}
                                        class={
                                            button.style === 'secondary'

                                                ? 'inline-flex items-center justify-center rounded-xl border border-slate-300 px-6 py-3 font-semibold text-slate-700 transition hover:border-[#1C64A5] hover:text-[#1C64A5]'

                                                : 'inline-flex items-center justify-center rounded-xl bg-[#1C64A5] px-6 py-3 font-semibold text-white transition hover:bg-[#17548a]'
                                        }
                                    >

                                        {button.text}

                                    </a>

                                )
                            )
                        }

                    </div>

                )
            }

            {
                data.note && (

                    <p
                        class="mt-8 text-sm text-slate-500"
                    >

                        {data.note}

                    </p>

                )
            }

        </div>

        {
            data.code && (

                <div
                    class="mx-auto w-full max-w-xl lg:max-w-none"
                >

                    <CodeBlock
                        code={data.code}
                    />

                </div>

            )
        }

    </div>

</section>