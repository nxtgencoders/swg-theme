---
import CodeBlock
    from '../marketing/CodeBlock.astro';

const code = `{
  "title": "Homepage",
  "template": "homepage"
}`;
---

<section
    class="overflow-hidden py-16 sm:py-20 lg:py-24"
>

    <div
        class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-[1fr_1.1fr] lg:gap-20 lg:px-8"
    >

        <div
            class="max-w-2xl"
        >

            <span
                class="inline-flex rounded-full border border-blue-200 bg-blue-50 px-4 py-1 text-sm font-medium text-[#1C64A5]"
            >

                Static Website Generator

            </span>

            <h1
                class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
            >

                Build blazing fast
                <br />

                static websites

                <span
                    class="block mt-2 text-[#1C64A5]"
                >

                    with Static Website Generator.

                </span>

            </h1>

            <p
                class="mt-8 max-w-xl text-lg leading-8 text-slate-600"
            >

                Create blogs, documentation websites and business
                websites using structured JSON content, reusable Astro
                themes and a modern publishing workflow.

            </p>

            <div
                class="mt-10 flex flex-col gap-4 sm:flex-row"
            >

                <a
                    href="/docs/getting-started"
                    class="inline-flex items-center justify-center rounded-xl bg-[#1C64A5] px-6 py-3 font-semibold text-white transition hover:bg-[#17548a]"
                >

                    Get Started

                </a>

                <a
                    href="/themes"
                    class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-6 py-3 font-semibold text-slate-700 transition hover:border-[#1C64A5] hover:text-[#1C64A5]"
                >

                    Browse Themes

                </a>

            </div>

            <p
                class="mt-8 text-sm text-slate-500"
            >

                Free • Open Source • Built with Astro

            </p>

        </div>

        <div
            class="mx-auto w-full max-w-xl lg:max-w-none"
        >

            <CodeBlock
                code={code}
            />

        </div>

    </div>

</section>