---
const {
    data
} = Astro.props;
---

<section
    class="border-y border-slate-200 bg-slate-50 py-12"
>

    <div
        class="mx-auto max-w-7xl px-6 lg:px-8"
    >

        {
            data.title && (

                <p
                    class="text-center text-sm font-semibold uppercase tracking-widest text-slate-500"
                >

                    {data.title}

                </p>

            )
        }

        {
            data.items?.length > 0 && (

                <div
                    class="mt-10 grid grid-cols-2 gap-8 text-center sm:grid-cols-3 lg:grid-cols-6"
                >

                    {
                        data.items.map(
                            item => (

                                <div
                                    class="rounded-xl border border-slate-200 bg-white px-6 py-5"
                                >

                                    {
                                        item.logo && (

                                            <img
                                                src={item.logo}
                                                alt={item.name}
                                                class="mx-auto h-8 w-auto"
                                            />

                                        )
                                    }

                                    {
                                        item.name && (

                                            <span
                                                class="text-lg font-bold text-slate-800"
                                            >

                                                {item.name}

                                            </span>

                                        )
                                    }

                                </div>

                            )
                        )
                    }

                </div>

            )
        }

    </div>

</section>