---
const {
    page
} = Astro.props;
---

<section
    class="border-b border-slate-200 bg-slate-50 py-20"
>

    <div
        class="mx-auto max-w-4xl px-6 lg:px-8"
    >

        <h1
            class="text-5xl font-extrabold tracking-tight text-slate-900"
        >

            {page.title}

        </h1>

        {
            page.excerpt && (

                <p
                    class="mt-6 text-xl leading-8 text-slate-600"
                >

                    {page.excerpt}

                </p>

            )
        }

    </div>

</section>