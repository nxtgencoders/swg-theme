---
import '../styles/base.css';

import SEO
    from '../components/seo/SEO.astro';

import Assets
    from '../components/layout/Assets.astro';

import {
    getSettings
}
from '../lib/settings';

const settings =
    getSettings();

const {
    page
} = Astro.props;
---

<!doctype html>

<html lang="en">

<head>

    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <SEO
        page={page}
        settings={settings}
    />

    <slot name="head" />

    <Assets
        location="head"
    />

</head>

<body>

    <slot />

    <slot name="scripts" />

    <Assets
        location="footer"
    />
</body>

</html>
