---
import '../styles/base.css';

import SEO
    from '../components/seo/SEO.astro';

export interface Props {

    title?: string;

}

const {

    title = 'Static Website Generator'

} = Astro.props;
---

<!doctype html>

<html lang="en">

<head>

    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <SEO
        page={page}
        settings={settings}
    />

    <!-- Tailwind CSS -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    <!-- Lucide ICONS -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/lucide@1.24.0/dist/umd/lucide.min.js"></script>
    
    <slot name="head" />

</head>

<body>

    <slot />

    <slot name="scripts" />

<script>
    lucide.createIcons();
</script>
</body>

</html>
