---
import '../styles/base.css';

export interface Props {

    title?: string;

}

const {

    title = 'Static Website Generator'

} = Astro.props;
---

<!doctype html>

<html lang="en">

<head>

    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <title>{title}</title>

    <!-- Tailwind CSS -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <slot name="head" />

</head>

<body>

    <slot />

    <slot name="scripts" />

</body>

</html>
