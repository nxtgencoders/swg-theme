---
import Page
    from '../templates/Page.astro';

import {
    getPages,
    getPage
}
from '../lib/pages';


export async function getStaticPaths() {

    return getPages()

        .filter(
            page =>
                !page.is_homepage
        )

        .map(page => ({

            params: {

                slug:
                    page.slug

            }

        }));
}

const page =
    getPage(
        Astro.params.slug!
    );


---

<Page />

