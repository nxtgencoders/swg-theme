---
/**
 * SWG Theme Starter
 *
 * Template:
 * Blog Article
 */

import BaseLayout
    from '../layouts/BaseLayout.astro';

import Header
    from '../components/layout/Header.astro';

import Footer
    from '../components/layout/Footer.astro';

import CTA
    from '../components/sections/CTA.astro';

import MarkdownContent
    from '../components/content/MarkdownContent.astro';

const {
    article,
    category
} = Astro.props;

const cta =
    category.sections?.find(
        section =>
            section.type === 'cta'
    );
---

<BaseLayout
    page={article}
>

    <Header />

    <section
        class="border-b border-slate-200 bg-slate-50 py-20"
    >

        <div
            class="mx-auto max-w-4xl px-6 lg:px-8"
        >

            <p
                class="text-sm font-semibold uppercase tracking-widest text-[#1C64A5]"
            >

                {category?.name}

            </p>

            <h1
                class="mt-4 text-5xl font-extrabold tracking-tight text-slate-900"
            >

                {article.title}

            </h1>

            <div
                class="mt-6 flex items-center gap-6 text-sm text-slate-500"
            >

                <span>

                    {
                        new Date(
                            article.published_at
                        ).toLocaleDateString(
                            'en-US',
                            {
                                year: 'numeric',
                                month: 'long',
                                day: 'numeric'
                            }
                        )
                    }

                </span>

                <span>

                    {article.reading_time}
                    {' '}
                    min read

                </span>

            </div>

        </div>

    </section>

    <MarkdownContent
        page={article}
    />

    {cta && (

        <CTA
            data={cta.data}
        />

    )}

    <Footer />

</BaseLayout>