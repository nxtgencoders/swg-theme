---
/**
 * SWG Theme Starter
 *
 * Template:
 * Blog Category
 *
 * This template is rendered by:
 *
 * src/pages/blog/[category]/index.astro
 */

import BaseLayout
    from '../layouts/BaseLayout.astro';

import Header
    from '../components/layout/Header.astro';

import Footer
    from '../components/layout/Footer.astro';

import CTA
    from '../components/sections/CTA.astro';

import {
    getArticleUrl
}
from '../lib/blog';

const {
    category,
    articles
} = Astro.props;

const page = {

    title:
        category.name,

    meta_title:
        category.name,

    meta_description:
        category.description,

    canonical_url:
        `/blog/${category.slug}`,

    noindex:
        0,

    sections:
        category.sections ?? []

};

const cta =
    category.sections?.find(
        section =>
            section.type === 'cta'
    );
---

<BaseLayout
    page={page}
>

    <Header />

    <section
        class="border-b border-slate-200 bg-slate-50 py-20"
    >

        <div
            class="mx-auto max-w-4xl px-6 text-center lg:px-8"
        >

            <span
                class="text-sm font-semibold uppercase tracking-widest text-[#1C64A5]"
            >

                Blog

            </span>

            <h1
                class="mt-4 text-5xl font-extrabold tracking-tight text-slate-900"
            >

                {category.name}

            </h1>

            <p
                class="mt-6 text-xl leading-8 text-slate-600"
            >

                {category.description}

            </p>

        </div>

    </section>

    <section
        class="py-20"
    >

        <div
            class="mx-auto grid max-w-7xl gap-8 px-6 md:grid-cols-2 lg:grid-cols-3 lg:px-8"
        >

            {
                articles.map(
                    article => (

                        <article
                            class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
                        >

                            {
                                article.featured_image && (

                                    <img
                                        src={`/media/${article.featured_image}`}
                                        alt={article.title}
                                        class="aspect-[16/9] w-full object-cover"
                                    />

                                )
                            }

                            <div
                                class="p-8"
                            >

                                <div
                                    class="flex items-center justify-between text-sm text-slate-500"
                                >

                                    <span>

                                        {
                                            new Date(
                                                article.published_at
                                            ).toLocaleDateString(
                                                'en-US',
                                                {
                                                    year: 'numeric',
                                                    month: 'long',
                                                    day: 'numeric'
                                                }
                                            )
                                        }

                                    </span>

                                    <span>

                                        {article.reading_time}
                                        {' '}
                                        min read

                                    </span>

                                </div>

                                <h2
                                    class="mt-4 text-2xl font-bold text-slate-900"
                                >

                                    <a
                                        href={getArticleUrl(article)}
                                        class="transition hover:text-[#1C64A5]"
                                    >

                                        {article.title}

                                    </a>

                                </h2>

                                {
                                    article.excerpt && (

                                        <p
                                            class="mt-4 leading-7 text-slate-600"
                                        >

                                            {article.excerpt}

                                        </p>

                                    )
                                }

                                <a
                                    href={getArticleUrl(article)}
                                    class="mt-8 inline-flex items-center font-semibold text-[#1C64A5]"
                                >

                                    Read article →

                                </a>

                            </div>

                        </article>

                    )
                )
            }

        </div>

    </section>

        {cta && (

            <CTA
                data={cta.data}
            />

        )}


    <Footer />

</BaseLayout>