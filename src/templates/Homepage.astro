---
import BaseLayout
    from '../layouts/BaseLayout.astro';

import Header
    from '../components/layout/Header.astro';

import Hero
    from '../components/sections/Hero.astro';

import LogoCloud
    from '../components/sections/LogoCloud.astro';

import FeaturesGrid
    from '../components/sections/FeaturesGrid.astro';

import BenefitsGrid
    from '../components/sections/BenefitsGrid.astro';

import CodeExample
    from '../components/sections/CodeExample.astro';

import FAQ
    from '../components/sections/FAQ.astro';

import CTA
    from '../components/sections/CTA.astro';

import Footer
    from '../components/layout/Footer.astro';

const {
    page
} = Astro.props;

---

<BaseLayout
    page={page}
>

    <Header />

    <Hero
        data={page.sections[0].data}
    />

    <LogoCloud
        data={page.sections[1].data}
    />

    <FeaturesGrid 
        data={page.sections[2].data}
    />

    <BenefitsGrid
        data={page.sections[3].data}
    />

    <CodeExample
        data={page.sections[4].data}
    />

    <FAQ />

    <CTA />

    <Footer />

</BaseLayout>

