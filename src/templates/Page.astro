---
import BaseLayout
    from '../layouts/BaseLayout.astro';

import Header
    from '../components/layout/Header.astro';

import PageHero
    from '../components/sections/PageHero.astro';

import MarkdownContent
    from '../components/content/MarkdownContent.astro';

import CTA
    from '../components/sections/CTA.astro';

import Footer
    from '../components/layout/Footer.astro';

const {
    page
} = Astro.props;
---

<BaseLayout
    title={page.title}
>

    <Header />

    <PageHero
        page={page}
    />

    <MarkdownContent
        page={page}
    />

    <CTA />

    <Footer />

</BaseLayout>